# Retell AI Configuration
RETELL_API_KEY=your_retell_api_key_here
RETELL_AGENT_ID=your_retell_agent_id_here

# Vapi AI Configuration
VAPI_API_KEY=your_vapi_api_key_here
VAPI_PHONE_NUMBER=+1234567890

# GoHighLevel Configuration
GHL_API_KEY=your_ghl_api_key_here
GHL_ACCOUNT_ID=your_ghl_account_id_here
GHL_WEBHOOK_SECRET=your_webhook_secret_here

# Airtable Configuration
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_airtable_base_id_here
AIRTABLE_LEADS_TABLE=Leads
AIRTABLE_CALLS_TABLE=Calls

# Calendar/Booking Configuration
CALENDAR_SERVICE=google  # google, outlook, custom
CALENDAR_API_KEY=your_calendar_api_key_here

# OpenAI Configuration (for LLM intent detection)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Application Configuration
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=sqlite:///./voice_agent.db

# Webhook Configuration
WEBHOOK_TIMEOUT=30
MAX_RETRIES=3
